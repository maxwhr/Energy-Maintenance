{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task27a_huawei_sun2000_engineering_candidate_v2.schema.json",
  "title": "Task 27A Huawei SUN2000 expert evidence dataset v2",
  "type": "object",
  "required": [
    "dataset_id",
    "version",
    "status",
    "scope_id",
    "parent_dataset_id",
    "parent_dataset_sha256",
    "expert_review_csv_sha256",
    "composition",
    "cases"
  ],
  "properties": {
    "dataset_id": {
      "const": "task27a_huawei_sun2000_engineering_candidate_v2"
    },
    "version": {
      "const": "2.0.0"
    },
    "status": {
      "const": "ENGINEERING_CANDIDATE"
    },
    "scope_id": {
      "type": "string"
    },
    "parent_dataset_id": {
      "const": "task27a_huawei_sun2000_engineering_candidate_v1"
    },
    "parent_dataset_sha256": {
      "const": "9d2400a26f2a50ea3894b46ee2d5e2f88392ee1a539695a9467490e6d9ff20b0"
    },
    "expert_review_csv_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "composition": {
      "type": "object"
    },
    "cases": {
      "type": "array",
      "minItems": 30,
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "query",
          "expected_document_ids",
          "expected_chunk_ids",
          "required_answer_points",
          "prohibited_answer_points",
          "safety_required",
          "should_abstain"
        ],
        "properties": {
          "case_id": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "expected_document_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_chunk_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_answer_points": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prohibited_answer_points": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "safety_required": {
            "type": "boolean"
          },
          "should_abstain": {
            "type": "boolean"
          },
          "accepted_evidence_sets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "evidence_set_id",
                "chunk_ids",
                "document_ids",
                "preferred",
                "required_answer_points_covered",
                "applicable_models",
                "numeric_parameter_constraints",
                "safety_constraints",
                "source_constraints",
                "replacement_rationale",
                "reviewer_name",
                "review_date",
                "expert_comments"
              ],
              "properties": {
                "evidence_set_id": {
                  "type": "string",
                  "minLength": 1
                },
                "chunk_ids": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string"
                  }
                },
                "document_ids": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string"
                  }
                },
                "preferred": {
                  "type": "boolean"
                },
                "required_answer_points_covered": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string"
                  }
                },
                "applicable_models": {
                  "type": "array",
                  "uniqueItems": true,
                  "items": {
                    "type": "string"
                  }
                },
                "numeric_parameter_constraints": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "safety_constraints": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "source_constraints": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "manufacturer",
                    "official_source_required",
                    "document_status",
                    "parse_status",
                    "review_status",
                    "chunk_status"
                  ],
                  "properties": {
                    "manufacturer": {
                      "const": "huawei"
                    },
                    "official_source_required": {
                      "const": true
                    },
                    "document_status": {
                      "const": "active"
                    },
                    "parse_status": {
                      "const": "parsed"
                    },
                    "review_status": {
                      "const": "approved"
                    },
                    "chunk_status": {
                      "const": "active"
                    }
                  }
                },
                "replacement_rationale": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "reviewer_name": {
                  "type": "string",
                  "minLength": 1
                },
                "review_date": {
                  "type": "string",
                  "format": "date"
                },
                "expert_comments": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
