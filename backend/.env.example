APP_NAME=Energy-Maintenance
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false

HOST=127.0.0.1
PORT=8000

# Required: replace this placeholder with a long random value before production deployment.
SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Local development only. Production initialization must set ADMIN_PASSWORD explicitly.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=System Administrator

DATABASE_URL=postgresql+psycopg://energy_user:energy_password@127.0.0.1:5432/energy_maintenance

UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_DOCUMENT_EXTENSIONS=txt,md,pdf,docx

DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=150
LOG_DIR=.runtime/logs

MODEL_GATEWAY_DEFAULT_PROVIDER=rule_based
MODEL_GATEWAY_TIMEOUT_SECONDS=20
MODEL_GATEWAY_ENABLE_LOGGING=true
MODEL_GATEWAY_ALLOW_FALLBACK=true

LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080
LOCAL_LLM_MODEL=local-gguf-model
LOCAL_LLM_API_TYPE=openai_compatible
LOCAL_LLM_TIMEOUT_SECONDS=60
LOCAL_LLM_MAX_TOKENS=1024
LOCAL_LLM_TEMPERATURE=0.2
LOCAL_LLM_HEALTH_PATH=/health
LOCAL_LLM_NATIVE_COMPLETION_PATH=/completion
LOCAL_LLM_OPENAI_CHAT_PATH=/v1/chat/completions

OCR_ENABLED=false
OCR_PROVIDER=tesseract
OCR_LANG=chi_sim+eng
OCR_TIMEOUT_SECONDS=30
OCR_MAX_IMAGE_MB=10
OCR_TESSERACT_CMD=tesseract

CLOUD_LLM_ENABLED=false
# Example: https://api.example.com or https://api.example.com/v1.
# Do not commit a real API key.
CLOUD_LLM_BASE_URL=
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=
CLOUD_LLM_API_TYPE=openai_compatible
CLOUD_LLM_TIMEOUT_SECONDS=60
CLOUD_LLM_MAX_TOKENS=1024
CLOUD_LLM_TEMPERATURE=0.2

MIMO_ENABLED=false
MIMO_BASE_URL=
MIMO_API_KEY=
MIMO_MODEL=mimo-2.5
MIMO_API_PROFILE=openai_compatible_vision
MIMO_TIMEOUT_SECONDS=60
MIMO_MAX_TOKENS=2048
MIMO_TEMPERATURE=0.1

CLOUD_VISION_ENABLED=false
CLOUD_VISION_BASE_URL=
CLOUD_VISION_API_KEY=
CLOUD_VISION_MODEL=

OCR_API_ENABLED=false
OCR_API_BASE_URL=
OCR_API_KEY=
OCR_API_MODEL=

# ----------------------------------------------------------------------
# Vector Retrieval / DashVector
# ----------------------------------------------------------------------
VECTOR_SEARCH_ENABLED=true
VECTOR_BACKEND=dashvector
VECTOR_TOP_K=8
VECTOR_MIN_SCORE=0.25
VECTOR_DISTANCE=cosine

DASHVECTOR_ENABLED=false
DASHVECTOR_ENDPOINT=https://vrs-cn-2r34utrl60002l.dashvector.cn-beijing.aliyuncs.com
DASHVECTOR_API_KEY=
DASHVECTOR_COLLECTION=energy_maintenance_knowledge
DASHVECTOR_NAMESPACE=default
DASHVECTOR_TIMEOUT_SECONDS=60
DASHVECTOR_CREATE_COLLECTION_IF_NOT_EXISTS=true
DASHVECTOR_DIMENSION=0
DASHVECTOR_METRIC=cosine

HYBRID_RETRIEVAL_ENABLED=true
HYBRID_KEYWORD_WEIGHT=0.35
HYBRID_VECTOR_WEIGHT=0.65
HYBRID_MIN_SCORE=0.20

# ----------------------------------------------------------------------
# Embedding Provider
# Keep real keys out of Git. Deterministic test embeddings are for local
# repeatable tests only and are not production semantic embeddings.
# ----------------------------------------------------------------------
EMBEDDING_ENABLED=false
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIM=0
EMBEDDING_API_TYPE=openai_compatible
EMBEDDING_EMBEDDINGS_PATH=/embeddings
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_SECONDS=60

EMBEDDING_TEST_PROVIDER_ENABLED=true
EMBEDDING_TEST_DIM=384

RERANK_ENABLED=false
RERANK_PROVIDER=openai_compatible
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=
RERANK_TOP_K=5

# ----------------------------------------------------------------------
# Security Hardening
# ----------------------------------------------------------------------
SECURITY_REQUIRE_STRONG_PRODUCTION_CONFIG=true
SECURITY_MIN_SECRET_KEY_LENGTH=32
SECURITY_MIN_ADMIN_PASSWORD_LENGTH=10
SECURITY_MAX_REQUEST_BODY_MB=20
SECURITY_MAX_JSON_BODY_MB=5

# Rate Limit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXEMPT_PATHS=/api/health,/api/system/status,/docs,/openapi.json

# CORS
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8010,http://localhost:8010,http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type

# Security Scan
SECURITY_SCAN_EXCLUDE_DIRS=node_modules,.venv,dist,backend/static/frontend/assets,delivery,delivery_staging,.git
SECURITY_SCAN_ALLOW_ENV_FILE=true

# Real external API calls remain disabled unless explicitly enabled for a
# controlled online acceptance task. Key presence alone must not trigger calls.
EXTERNAL_REAL_CALLS_ENABLED=false
