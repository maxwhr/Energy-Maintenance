APP_NAME=Energy-Maintenance
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false

HOST=127.0.0.1
PORT=8000

# Required: replace this placeholder with a long random value before production deployment.
SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Local development only. Production initialization must set ADMIN_PASSWORD explicitly.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=System Administrator

DATABASE_URL=postgresql+psycopg://energy_user:energy_password@127.0.0.1:5432/energy_maintenance

UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_DOCUMENT_EXTENSIONS=txt,md,pdf,docx

DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=150
LOG_DIR=.runtime/logs

MODEL_GATEWAY_DEFAULT_PROVIDER=rule_based
MODEL_GATEWAY_TIMEOUT_SECONDS=20
MODEL_GATEWAY_ENABLE_LOGGING=true
MODEL_GATEWAY_ALLOW_FALLBACK=true

LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080
LOCAL_LLM_MODEL=local-gguf-model
LOCAL_LLM_API_TYPE=openai_compatible
LOCAL_LLM_TIMEOUT_SECONDS=60
LOCAL_LLM_MAX_TOKENS=1024
LOCAL_LLM_TEMPERATURE=0.2
LOCAL_LLM_HEALTH_PATH=/health
LOCAL_LLM_NATIVE_COMPLETION_PATH=/completion
LOCAL_LLM_OPENAI_CHAT_PATH=/v1/chat/completions

OCR_ENABLED=false
OCR_PROVIDER=tesseract
OCR_LANG=chi_sim+eng
OCR_TIMEOUT_SECONDS=30
OCR_MAX_IMAGE_MB=10
OCR_TESSERACT_CMD=tesseract

# Task 25C: real OCR/vision probes are disabled unless explicitly authorized.
TASK25C_ALLOW_REAL_API=false
MULTIMODAL_MAX_IMAGE_PIXELS=40000000
MULTIMODAL_PREPROCESS_MAX_EDGE=2400
MULTIMODAL_MAX_MEDIA_PER_CASE=10
MULTIMODAL_OCR_MIN_CONFIDENCE=0.75
MULTIMODAL_VISION_MIN_CONFIDENCE=0.70
MULTIMODAL_CONFIRMED_MIN_CONFIDENCE=0.85

CLOUD_LLM_ENABLED=false
# Example: https://api.example.com or https://api.example.com/v1.
# Do not commit a real API key.
CLOUD_LLM_BASE_URL=
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=
CLOUD_LLM_API_TYPE=openai_compatible
CLOUD_LLM_TIMEOUT_SECONDS=60
CLOUD_LLM_MAX_TOKENS=1024
CLOUD_LLM_TEMPERATURE=0.2
STRUCTURED_OUTPUT_MODE=auto
STRUCTURED_OUTPUT_PROBE_ENABLED=true
QUERY_UNDERSTANDING_TIMEOUT_SECONDS=8
RERANK_TIMEOUT_SECONDS=10

# ----------------------------------------------------------------------
# MiniMax-M3 structured tool calling
# Keep MINIMAX_API_KEY empty in examples. The standard service tier is the
# default; priority must only be enabled after explicit cost authorization.
# ----------------------------------------------------------------------
MINIMAX_ENABLED=false
MINIMAX_API_KEY=
MINIMAX_PROTOCOL=anthropic
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_OPENAI_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_QUERY_UNDERSTANDING_MODEL=MiniMax-M3
MINIMAX_TIEBREAK_MODEL=MiniMax-M3
MINIMAX_THINKING_TYPE=disabled
MINIMAX_TOOL_CALL_ENABLED=true
MINIMAX_FORCE_TOOL_CHOICE=true
MINIMAX_SERVICE_TIER=standard
MINIMAX_TEMPERATURE=0
MINIMAX_TOP_P=0.9
MINIMAX_QUERY_MAX_TOKENS=1024
MINIMAX_TIEBREAK_MAX_TOKENS=768
MINIMAX_QUERY_TIMEOUT_SECONDS=8
MINIMAX_TIEBREAK_TIMEOUT_SECONDS=7
MINIMAX_MAX_RETRIES=0
MINIMAX_MAX_TIEBREAK_CANDIDATES=6
MINIMAX_CACHE_TTL_SECONDS=900
MINIMAX_CACHE_MAX_ENTRIES=256
MINIMAX_CIRCUIT_COOLDOWN_SECONDS=60

RAG_QUERY_UNDERSTANDING_PROVIDER=minimax
RAG_QUERY_UNDERSTANDING_RUNTIME_MODEL=deterministic
RAG_QUERY_UNDERSTANDING_SCHEMA_VERSION=query_understanding_v2
RAG_QUERY_UNDERSTANDING_PROMPT_VERSION=task25b_r3_dev_r5_r3_mm_v2
RAG_QUERY_UNDERSTANDING_TOTAL_BUDGET_SECONDS=4
RAG_TIEBREAK_PROVIDER=minimax
RAG_DETERMINISTIC_RERANK_ENABLED=true
RAG_OPTIONAL_LLM_TIEBREAK_ENABLED=true
RAG_TIEBREAK_EXPERIMENTAL_ENABLED=false
RAG_REQUEST_LEVEL_PROVIDER_FALLBACK_ENABLED=false
RAG_QUERY_WEIGHT_ORIGINAL=1.0
RAG_QUERY_WEIGHT_CANONICAL=0.95
RAG_QUERY_WEIGHT_INTENT=0.86
RAG_QUERY_WEIGHT_CONDITION=0.82
DETERMINISTIC_RERANK_WEIGHTS_VERSION=task25b_r3_dev_r5_r2_mm_v1
DETERMINISTIC_RERANK_NORMALIZED_RRF_WEIGHT=0.25
DETERMINISTIC_RERANK_INTENT_WEIGHT=0.16
DETERMINISTIC_RERANK_EXACT_MODEL_WEIGHT=0.12
DETERMINISTIC_RERANK_EXACT_ALARM_WEIGHT=0.12
DETERMINISTIC_RERANK_SEMANTIC_WEIGHT=0.10
DETERMINISTIC_RERANK_KEYWORD_WEIGHT=0.07
DETERMINISTIC_RERANK_VECTOR_WEIGHT=0.06
DETERMINISTIC_RERANK_CONDITION_WEIGHT=0.04
DETERMINISTIC_RERANK_CITATION_WEIGHT=0.04
DETERMINISTIC_RERANK_SOURCE_WEIGHT=0.04
MINIMAX_TIEBREAK_RELATIVE_MARGIN=0.08

# ----------------------------------------------------------------------
# Qwen3 Dedicated Passage Rerank
# Reuse DASHSCOPE_API_KEY. Supply the exact workspace-scoped Model Studio
# Base URL; the application will not guess a WorkspaceId or reuse another
# workspace/provider URL. Keep these fields empty/disabled until configured.
# ----------------------------------------------------------------------
DASHSCOPE_API_KEY=
DASHSCOPE_RERANK_ENABLED=false
DASHSCOPE_RERANK_MODEL=qwen3-rerank
DASHSCOPE_RERANK_BASE_URL=
DASHSCOPE_RERANK_ENDPOINT=/reranks
DASHSCOPE_RERANK_TIMEOUT_SECONDS=3
DASHSCOPE_RERANK_MAX_DOCUMENTS=40
DASHSCOPE_RERANK_TOP_N=40
DASHSCOPE_RERANK_CACHE_ENABLED=true
DASHSCOPE_RERANK_CACHE_TTL_SECONDS=900
DASHSCOPE_RERANK_CACHE_MAX_ENTRIES=256
DASHSCOPE_RERANK_CIRCUIT_FAILURE_THRESHOLD=3
DASHSCOPE_RERANK_CIRCUIT_COOLDOWN_SECONDS=60
RAG_DEDICATED_RERANK_ENABLED=false
RAG_DEDICATED_RERANK_PROVIDER=dashscope
RAG_DEDICATED_RERANK_MODEL=qwen3-rerank

MIMO_ENABLED=false
MIMO_BASE_URL=
MIMO_API_KEY=
MIMO_MODEL=mimo-2.5
MIMO_API_PROFILE=openai_compatible_vision
MIMO_TIMEOUT_SECONDS=60
MIMO_MAX_TOKENS=2048
MIMO_TEMPERATURE=0.1

CLOUD_VISION_ENABLED=false
CLOUD_VISION_BASE_URL=
CLOUD_VISION_API_KEY=
CLOUD_VISION_MODEL=

OCR_API_ENABLED=false
OCR_API_BASE_URL=
OCR_API_KEY=
OCR_API_MODEL=

# ----------------------------------------------------------------------
# Vector Retrieval / DashVector
# ----------------------------------------------------------------------
VECTOR_SEARCH_ENABLED=true
VECTOR_BACKEND=dashvector
VECTOR_TOP_K=8
VECTOR_MIN_SCORE=0.25
VECTOR_DISTANCE=cosine

# Use the HTTPS Cluster Endpoint from DashVector cluster details, not an Aliyun product page.
DASHVECTOR_ENABLED=false
DASHVECTOR_ENDPOINT=https://YOUR_CLUSTER_ENDPOINT
DASHVECTOR_API_KEY=<DASHVECTOR_API_KEY>
DASHVECTOR_COLLECTION=energy_maintenance_knowledge_te_v4_1024_v1
DASHVECTOR_MEDIA_COLLECTION=energy_maintenance_media_te_v4_1024_v1
# Provider-safe physical names (DashVector enforces a 32-character maximum).
DASHVECTOR_PHYSICAL_COLLECTION=energy_kn_te_v4_1024_v1
DASHVECTOR_PHYSICAL_MEDIA_COLLECTION=energy_media_te_v4_1024_v1
DASHVECTOR_R1_CANARY_COLLECTION=energy_kn_te_v4_1024_r1
DASHVECTOR_R1_CANARY_MEDIA_COLLECTION=energy_media_te_v4_1024_r1
DASHVECTOR_NAMESPACE=default
DASHVECTOR_TIMEOUT_SECONDS=60
DASHVECTOR_CREATE_COLLECTION_IF_NOT_EXISTS=true
DASHVECTOR_DIMENSION=1024
DASHVECTOR_METRIC=cosine
DASHVECTOR_DTYPE=float
DASHVECTOR_UPSERT_BATCH_SIZE=50
DASHVECTOR_QUERY_TOP_K=30
DASHVECTOR_REAL_CALL_ENABLED=false
DASHVECTOR_USE_PARTITIONS=true
DASHVECTOR_BASE_PARTITION=
DASHVECTOR_PILOT_PARTITION=pilot_r2
DASHVECTOR_CREATE_PARTITION_IF_NOT_EXISTS=true

HYBRID_RETRIEVAL_ENABLED=true
HYBRID_KEYWORD_WEIGHT=0.35
HYBRID_VECTOR_WEIGHT=0.65
HYBRID_MIN_SCORE=0.20

# ----------------------------------------------------------------------
# Embedding Provider
# Keep real keys out of Git. Deterministic test embeddings are for local
# repeatable tests only and are not production semantic embeddings. The embedding
# and collection dimensions must match. text-embedding-v4 accepts at most 10 inputs per batch.
# ----------------------------------------------------------------------
EMBEDDING_ENABLED=false
EMBEDDING_PROVIDER=dashscope_openai_compatible
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=<DASHSCOPE_API_KEY>
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
EMBEDDING_API_TYPE=openai_compatible
EMBEDDING_EMBEDDINGS_PATH=/embeddings
EMBEDDING_ENCODING_FORMAT=float
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_INPUT_TOKENS=8192
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=4
EMBEDDING_RETRY_BASE_SECONDS=1
EMBEDDING_REAL_CALL_ENABLED=false
EMBEDDING_INDEX_VERSION=text-embedding-v4-1024-v1
EMBEDDING_QUERY_CACHE_TTL_SECONDS=300
EMBEDDING_QUERY_CACHE_MAX_ENTRIES=512
EMBEDDING_MAX_CONCURRENCY=2

# Keep keyword as the production default until the frozen R1 blind gate passes.
RETRIEVAL_DEFAULT_MODE=keyword
RETRIEVAL_VECTOR_MIN_USEFUL_SCORE=0.76
RETRIEVAL_RRF_K=60
RETRIEVAL_TOTAL_BUDGET_MS=3500
RETRIEVAL_VECTOR_TIMEOUT_SECONDS=3.5
RETRIEVAL_ABSTENTION_MIN_SCORE=0.35
RETRIEVAL_ABSTENTION_MIN_MARGIN=0.02
RETRIEVAL_QUALITY_GATE_STATUS=PASSED_CONTROLLED_TEST_V2
RETRIEVAL_FEATURE_RERANK_ENABLED=false

# Both gates are mandatory for real calls. Full reindex remains independently protected.
TASK25B_ALLOW_REAL_API=false
TASK25B_ALLOW_FULL_REINDEX=false
RAG_QUERY_UNDERSTANDING_RUNTIME_MODEL=deterministic
RAG_MINIMAX_AMBIGUITY_RESOLVER_ENABLED=false
RAG_MINIMAX_AMBIGUITY_MODEL=MiniMax-M3
RAG_MINIMAX_AMBIGUITY_PROMPT_VERSION=task25b_r3_dev_r5_r4_mm_v1
RAG_MINIMAX_AMBIGUITY_TOTAL_BUDGET_SECONDS=5
RAG_MINIMAX_AMBIGUITY_MAX_TOKENS=160
TASK25B_R2_PILOT_ENABLED=false
TASK25B_R2_ALLOW_PILOT_INDEX=false
TASK25B_R2_ALLOW_PILOT_SWITCH=false
TASK25B_R2_ALLOW_PILOT_ROLLBACK=false
DASHVECTOR_PILOT_COLLECTION=energy_kn_te_v4_1024_pilot1
DASHVECTOR_PILOT_MEDIA_COLLECTION=energy_media_te_v4_1024_pilot1
RETRIEVAL_PILOT_MODE=adaptive_conservative

EMBEDDING_TEST_PROVIDER_ENABLED=true
EMBEDDING_TEST_DIM=384

RERANK_ENABLED=false
RERANK_PROVIDER=openai_compatible
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=
RERANK_TOP_K=5

# ----------------------------------------------------------------------
# Security Hardening
# ----------------------------------------------------------------------
SECURITY_REQUIRE_STRONG_PRODUCTION_CONFIG=true
SECURITY_MIN_SECRET_KEY_LENGTH=32
SECURITY_MIN_ADMIN_PASSWORD_LENGTH=10
SECURITY_MAX_REQUEST_BODY_MB=20
SECURITY_MAX_JSON_BODY_MB=5

# Rate Limit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXEMPT_PATHS=/api/health,/api/system/status,/docs,/openapi.json

# CORS
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8010,http://localhost:8010,http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type

# Security Scan
SECURITY_SCAN_EXCLUDE_DIRS=node_modules,.venv,dist,backend/static/frontend/assets,delivery,delivery_staging,.git
SECURITY_SCAN_ALLOW_ENV_FILE=true

# Real external API calls remain disabled unless explicitly enabled for a
# controlled online acceptance task. Key presence alone must not trigger calls.
EXTERNAL_REAL_CALLS_ENABLED=false
# Chinese-primary knowledge governance (English is retained but inactive by default)
KNOWLEDGE_PRIMARY_LANGUAGE=zh-CN
KNOWLEDGE_ALLOW_ENGLISH_RETRIEVAL=false
KNOWLEDGE_ALLOW_ENGLISH_PILOT=false
KNOWLEDGE_KEEP_ALTERNATE_LANGUAGE=true
KNOWLEDGE_PREFER_CHINESE_DUPLICATE=true
