# Copy to /etc/energy-maintenance/backend.env and replace every CHANGE_ME value.
APP_ENV=production
DEBUG=false
HOST=127.0.0.1
PORT=8012
WEB_CONCURRENCY=2
DATABASE_URL=postgresql+psycopg://energy_maintenance:CHANGE_ME@127.0.0.1:5432/energy_maintenance
SECRET_KEY=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
ADMIN_PASSWORD=CHANGE_ME_WITH_AT_LEAST_10_CHARACTERS
UPLOAD_DIR=/var/lib/energy-maintenance/uploads
MEDIA_PROCESSED_DIR=/var/lib/energy-maintenance/processed-media
TEMP_DIR=/var/lib/energy-maintenance/tmp
LOG_DIR=/var/log/energy-maintenance
CORS_ALLOWED_ORIGINS=https://CHANGE_ME_HOST
EXTERNAL_REAL_CALLS_ENABLED=false
TASK25B_ALLOW_REAL_API=false
TASK25B_ALLOW_FULL_REINDEX=false
VECTOR_SEARCH_ENABLED=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=1

